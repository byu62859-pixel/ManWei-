.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--mw-cream);
  position: relative;
}

/* ========== 页面标题 ========== */

.page-header {
  background: linear-gradient(160deg, #FFF5F0 0%, #FFE8E0 50%, #FFF0E8 100%);
  padding: 36rpx 28rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(45, 53, 97, 0.06);
  flex-shrink: 0;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--mw-text);
}

/* ========== 观后感列表 ========== */

.review-list {
  padding: 20rpx 24rpx;
  flex: 1;
}

/* ========== 卡片 ========== */

.review-card {
  display: flex;
  background: var(--mw-surface);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(45, 53, 97, 0.07);
  padding: 20rpx;
  margin-bottom: 16rpx;
  transition: transform var(--mw-dur-fast) var(--mw-ease-bounce),
              box-shadow var(--mw-dur-fast) var(--mw-ease) !important;
  animation: mw-fadeSlideUp var(--mw-dur-slow) var(--mw-ease-out) forwards;
}

.review-card:last-child {
  margin-bottom: 0;
}

.review-card:active {
  transform: scale(0.98) !important;
  box-shadow: 0 1rpx 8rpx rgba(45, 53, 97, 0.04) !important;
}

.card-cover {
  width: 136rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: var(--mw-cream-deep);
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--mw-text-muted);
}

.card-content {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.anime-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--mw-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 10rpx;
}

.content-summary {
  font-size: 26rpx;
  color: var(--mw-text-soft);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  flex: 1;
  margin-bottom: 10rpx;
  line-height: 1.6;
}

.update-time {
  font-size: 22rpx;
  color: var(--mw-text-muted);
  margin-top: auto;
}

/* ========== 空状态 ========== */

.empty-state {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: var(--mw-text-muted);
  font-size: 28rpx;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.25;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: var(--mw-text-muted);
  margin-top: 12rpx;
  opacity: 0.7;
}

/* ========== 加载更多 ========== */

.load-more {
  text-align: center;
  padding: 28rpx;
  color: var(--mw-text-muted);
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.load-more::before,
.load-more::after {
  content: '';
  width: 40rpx;
  height: 2rpx;
  background: var(--mw-border);
}

/* ========== 骨架屏 ========== */

.skeleton-mask {
  position: absolute;
  top: 96rpx;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--mw-cream);
  padding: 20rpx 24rpx;
}

.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.skeleton-card {
  display: flex;
  background: var(--mw-surface);
  border-radius: 20rpx;
  padding: 20rpx;
}

.skeleton-cover {
  width: 136rpx;
  height: 180rpx;
  border-radius: 12rpx;
  background: linear-gradient(90deg, var(--mw-cream-deep) 25%, var(--mw-cream) 50%, var(--mw-cream-deep) 75%);
  background-size: 400px 100%;
  animation: mw-shimmer-skeleton 1.6s ease-in-out infinite;
  flex-shrink: 0;
}

.skeleton-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.skeleton-title {
  width: 60%;
  height: 32rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, var(--mw-cream-deep) 25%, var(--mw-cream) 50%, var(--mw-cream-deep) 75%);
  background-size: 400px 100%;
  animation: mw-shimmer-skeleton 1.6s ease-in-out infinite;
  animation-delay: 50ms;
}

.skeleton-text {
  width: 90%;
  height: 80rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, var(--mw-cream-deep) 25%, var(--mw-cream) 50%, var(--mw-cream-deep) 75%);
  background-size: 400px 100%;
  animation: mw-shimmer-skeleton 1.6s ease-in-out infinite;
  animation-delay: 100ms;
}

.skeleton-time {
  width: 40%;
  height: 24rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, var(--mw-cream-deep) 25%, var(--mw-cream) 50%, var(--mw-cream-deep) 75%);
  background-size: 400px 100%;
  animation: mw-shimmer-skeleton 1.6s ease-in-out infinite;
  animation-delay: 150ms;
}