/* 区域 1：Logo 区 */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 120rpx;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: #FF6B6B;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.3);
}

.logo-char {
  font-size: 72rpx;
  font-weight: bold;
  color: #ffffff;
}

.app-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #2C2C2C;
  margin-top: 24rpx;
  letter-spacing: 0.1em;
}

.app-subtitle {
  font-size: 28rpx;
  color: #999999;
  margin-top: 12rpx;
}

/* 区域 2：表单卡片 */
.form-card {
  margin: 60rpx 40rpx 0;
  padding: 48rpx 40rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(255, 107, 107, 0.12);
}

.input-group {
  margin-bottom: 32rpx;
}

.input-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.input-row:first-child {
  border-top: 1rpx solid #F0F0F0;
}

.input-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  color: #2C2C2C;
  height: 60rpx;
  line-height: 60rpx;
}

.toggle-password {
  font-size: 36rpx;
  padding: 10rpx;
  flex-shrink: 0;
}

.btn-login {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #FF6B6B;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  margin-top: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.25);
}

.btn-login:active {
  opacity: 0.85;
}

.btn-register {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #ffffff;
  color: #FF6B6B;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  margin-top: 20rpx;
  border: 2rpx solid #FF6B6B;
}

.btn-register:active {
  background: #FFF8F8;
}

/* 区域 3：底部区域 */
.bottom-area {
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.divider {
  display: flex;
  align-items: center;
  width: 480rpx;
  margin-bottom: 48rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #E0E0E0;
}

.divider-text {
  font-size: 24rpx;
  color: #999999;
  padding: 0 24rpx;
  white-space: nowrap;
}

.wechat-btn {
  padding: 20rpx;
}

.wechat-icon-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
}
