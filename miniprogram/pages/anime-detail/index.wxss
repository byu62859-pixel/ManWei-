.page {
  min-height: 100vh;
  background: var(--mw-cream);
  position: relative;
}

/* ========== 顶部动漫信息区 ========== */
.anime-header {
  display: flex;
  background: linear-gradient(160deg, #FFF5F0 0%, #FFE8E0 50%, #FFF0E8 100%);
  padding: 32rpx 28rpx 40rpx;
  position: relative;
  overflow: hidden;
}

.anime-header::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 107, 107, 0.10) 0%, transparent 70%);
  pointer-events: none;
}

.anime-header::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: 20%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(160, 126, 246, 0.08) 0%, transparent 70%);
  pointer-events: none;
}

.anime-cover {
  width: 192rpx;
  height: 268rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: rgba(255,255,255,0.6);
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.15);
  border: 4rpx solid rgba(255,255,255,0.8);
}

.cover-placeholder {
  width: 192rpx;
  height: 268rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: rgba(255,255,255,0.5);
  border: 4rpx solid rgba(255,255,255,0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.anime-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.anime-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--mw-text);
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.3;
}

.anime-type {
  display: inline-flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--mw-coral);
  background: var(--mw-coral-soft);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  align-self: flex-start;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.anime-summary {
  margin-top: 8rpx;
  flex: 1;
}

.summary-text {
  font-size: 24rpx;
  color: var(--mw-text-soft);
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.summary-text.expanded {
  -webkit-line-clamp: unset;
  display: block;
}

.summary-toggle {
  font-size: 24rpx;
  color: var(--mw-coral);
  text-decoration: none;
  margin-top: 6rpx;
  display: inline-block;
  font-weight: 500;
}

/* ========== 操作区 ========== */
.anime-actions {
  margin-top: 24rpx;
  display: flex;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* 收藏按钮 */
.btn-favorite {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 36rpx;
  background: linear-gradient(135deg, var(--mw-coral) 0%, var(--mw-peach) 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 107, 0.30);
  transition: transform var(--mw-dur-fast) var(--mw-ease-bounce),
              box-shadow var(--mw-dur-fast) var(--mw-ease);
}

.btn-favorite:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 10rpx rgba(255, 107, 107, 0.22);
}

/* 收藏状态 */
.favorite-status {
  display: flex;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: 12rpx;
}

.status-text {
  background: rgba(255, 255, 255, 0.70);
  backdrop-filter: blur(8rpx);
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: var(--mw-text);
  font-weight: 500;
  box-shadow: 0 2rpx 12rpx rgba(45, 53, 97, 0.08);
}

.status-ops .op-btn {
  font-size: 24rpx;
  color: var(--mw-coral);
  font-weight: 500;
}

.status-picker {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  align-items: center;
  background: rgba(255,255,255,0.60);
  backdrop-filter: blur(8rpx);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.status-item {
  padding: 8rpx 20rpx;
  background: rgba(255,255,255,0.80);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: var(--mw-text-soft);
  transition: all var(--mw-dur-fast) var(--mw-ease-bounce);
}

.status-item.active {
  background: var(--mw-coral);
  color: #fff;
  font-weight: 700;
  box-shadow: 0 2rpx 10rpx rgba(255, 107, 107, 0.28);
}

.op-btn.cancel {
  text-decoration: none;
  opacity: 0.6;
  font-size: 24rpx;
  color: var(--mw-text-muted);
}

/* ========== 5星评分 ========== */
.star-row {
  display: flex;
  align-items: center;
  gap: 2rpx;
  margin-top: 14rpx;
}

.star {
  font-size: 36rpx;
  line-height: 1;
  color: var(--mw-border);
  transition: color var(--mw-dur-fast), transform var(--mw-dur-fast) var(--mw-ease-bounce);
}

.star.filled {
  color: var(--mw-gold);
}

.star.empty {
  color: var(--mw-border);
}

.rating-text {
  font-size: 24rpx;
  color: var(--mw-text-soft);
  margin-left: 12rpx;
}

.rating-text.dim {
  color: var(--mw-text-muted);
  font-size: 22rpx;
}

/* ========== Tab 栏 ========== */
.tab-bar {
  display: flex;
  background: var(--mw-surface);
  padding: 0 28rpx;
  border-bottom: 2rpx solid var(--mw-border);
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(45, 53, 97, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--mw-text-muted);
  position: relative;
  transition: color var(--mw-dur-fast), font-weight var(--mw-dur-fast);
}

.tab-item.active {
  color: var(--mw-coral);
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 56rpx;
  height: 4rpx;
  background: linear-gradient(90deg, var(--mw-coral), var(--mw-peach));
  border-radius: 2rpx;
  animation: mw-tabIndicator var(--mw-dur-normal) var(--mw-ease-bounce);
}

@keyframes mw-tabIndicator {
  from { width: 0; }
  to   { width: 56rpx; }
}

/* ========== Tab 内容区 ========== */
.tab-content {
  padding: 24rpx;
}

/* ========== 标签 Tab ========== */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 28rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  box-shadow: 0 2rpx 10rpx rgba(45, 53, 97, 0.06);
}

.tag-item.preset {
  background: var(--mw-lavender-soft);
  color: #7050d0;
}

.tag-item.custom {
  background: var(--mw-coral-soft);
  color: #d94040;
}

.tag-del {
  font-size: 32rpx;
  color: rgba(0,0,0,0.2);
  padding: 0 4rpx;
  transition: color var(--mw-dur-fast);
}

.tag-del:active {
  color: var(--mw-danger);
}

.empty-tags {
  text-align: center;
  padding: 60rpx 0;
  color: var(--mw-text-muted);
  font-size: 26rpx;
  background: var(--mw-surface);
  border-radius: 16rpx;
}

.add-tag-area {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.tag-input {
  flex: 1;
  height: 80rpx;
  background: var(--mw-surface);
  border-radius: 40rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid var(--mw-border);
  transition: border-color var(--mw-dur-fast), box-shadow var(--mw-dur-fast);
}

.tag-input:focus {
  border-color: var(--mw-coral);
  box-shadow: 0 0 0 4rpx rgba(255, 107, 107, 0.10);
  outline: none;
}

.btn-add-tag {
  width: 128rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--mw-coral) 0%, var(--mw-peach) 100%);
  color: #fff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.25);
  transition: transform var(--mw-dur-fast) var(--mw-ease-bounce),
              box-shadow var(--mw-dur-fast) var(--mw-ease);
}

.btn-add-tag:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.18);
}

.tips {
  text-align: center;
  color: var(--mw-text-muted);
  font-size: 26rpx;
  padding: 24rpx 0;
  background: var(--mw-surface);
  border-radius: 16rpx;
}

/* ========== 情绪曲线 Tab ========== */
.curve-tab {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.need-favorite {
  text-align: center;
  padding: 80rpx 0;
  color: var(--mw-text-muted);
  font-size: 28rpx;
  background: var(--mw-surface);
  border-radius: 16rpx;
}

.curve-chart {
  background: var(--mw-surface);
  border-radius: 16rpx;
  padding: 20rpx;
  height: 340rpx;
  box-shadow: 0 2rpx 16rpx rgba(45, 53, 97, 0.06);
}

.curve-tip {
  text-align: center;
  font-size: 24rpx;
  color: var(--mw-coral);
  padding: 8rpx 0 4rpx;
  min-height: 44rpx;
  font-weight: 500;
}

.curve-empty {
  text-align: center;
  padding: 28rpx;
  color: var(--mw-text-muted);
  font-size: 24rpx;
  background: var(--mw-surface);
  border-radius: 16rpx;
}

.curve-input-area {
  background: var(--mw-surface);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(45, 53, 97, 0.06);
}

.input-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 28rpx;
  color: var(--mw-text);
  margin-right: 16rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.episode-input {
  width: 120rpx;
  height: 72rpx;
  background: var(--mw-cream);
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: border-color var(--mw-dur-fast), box-shadow var(--mw-dur-fast);
}

.episode-input:focus {
  border-color: var(--mw-coral);
  box-shadow: 0 0 0 4rpx rgba(255, 107, 107, 0.10);
  outline: none;
}

.emotion-selector {
  margin-bottom: 24rpx;
}

.emotion-levels {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.emotion-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0;
  background: var(--mw-cream);
  border-radius: 16rpx;
  min-width: 0;
  border: 2rpx solid transparent;
  transition: all var(--mw-dur-fast) var(--mw-ease-bounce);
}

.emotion-item:active {
  transform: scale(0.95);
}

.emotion-emoji {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.emotion-label {
  font-size: 22rpx;
  color: var(--mw-text-soft);
}

.emotion-item.active {
  background: var(--mw-coral);
  border-color: var(--mw-coral);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.25);
}

.emotion-item.active .emotion-label {
  color: #fff;
  font-weight: 700;
}

.btn-save-curve {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, var(--mw-coral) 0%, var(--mw-peach) 100%);
  color: #fff;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 6rpx 24rpx rgba(255, 107, 107, 0.30);
  transition: transform var(--mw-dur-fast) var(--mw-ease-bounce),
              box-shadow var(--mw-dur-fast) var(--mw-ease);
}

.btn-save-curve:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.22);
}

/* ========== 观后感 Tab ========== */
.review-tab {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.review-textarea {
  width: 100%;
  height: 440rpx;
  background: var(--mw-surface);
  border-radius: 20rpx;
  padding: 28rpx;
  font-size: 28rpx;
  color: var(--mw-text);
  box-sizing: border-box;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 16rpx rgba(45, 53, 97, 0.06);
  transition: border-color var(--mw-dur-fast), box-shadow var(--mw-dur-fast);
}

.review-textarea:focus {
  border-color: var(--mw-coral);
  box-shadow: 0 0 0 4rpx rgba(255, 107, 107, 0.10);
  outline: none;
}

.review-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--mw-surface);
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
}

.word-count {
  font-size: 24rpx;
  color: var(--mw-text-muted);
}

.btn-save-review {
  padding: 16rpx 52rpx;
  background: linear-gradient(135deg, var(--mw-coral) 0%, var(--mw-peach) 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 107, 0.28);
  transition: transform var(--mw-dur-fast) var(--mw-ease-bounce),
              box-shadow var(--mw-dur-fast) var(--mw-ease);
}

.btn-save-review:active {
  transform: scale(0.97);
  opacity: 0.9;
}

/* ========== 加载遮罩 ========== */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(251, 249, 247, 0.85);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  transition: opacity var(--mw-dur-normal);
}

.loading-mask text {
  font-size: 28rpx;
  color: var(--mw-coral);
  font-weight: 500;
}