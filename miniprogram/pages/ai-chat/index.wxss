.ai-chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}
.messages {
  flex: 1;
  padding: 16rpx;
  box-sizing: border-box;
}
.message-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}
.user-row {
  flex-direction: row-reverse;
}
.ai-row {
  flex-direction: row;
}
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #e6f7ff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}
.avatar image {
  width: 100%;
  height: 100%;
}
.ai-avatar-icon {
  font-size: 28rpx;
  color: #1890ff;
  font-weight: bold;
}
.user-bubble {
  background: #FF6B6B;
  color: #fff;
  border-radius: 24rpx 24rpx 4rpx 24rpx;
  padding: 16rpx 24rpx;
  margin-left: 16rpx;
  margin-right: 16rpx;
  max-width: 70%;
  line-height: 1.5;
  word-break: break-word;
}
.ai-bubble {
  background: #fff;
  color: #333;
  border-radius: 24rpx 24rpx 24rpx 4rpx;
  padding: 16rpx 24rpx;
  margin-left: 16rpx;
  margin-right: 16rpx;
  max-width: 70%;
  line-height: 1.5;
  word-break: break-word;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.loading-bubble {
  padding: 24rpx 32rpx;
}
.loading-dots {
  display: flex;
  gap: 8rpx;
  align-items: center;
}
.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #999;
  animation: bounce 1.4s infinite ease-in-out;
}
.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}
.input-area {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  padding: 20rpx 24rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  gap: 16rpx;
  box-sizing: border-box;
}

.input-box {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: #333333;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 0 20rpx;
  line-height: 72rpx;
  box-sizing: border-box;
}
.placeholder-bottom {
  color: #999999;
  font-size: 28rpx;
  line-height: 72rpx;
  text-align: left;
}

.send-btn-active {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  flex-shrink: 0;
  padding: 0;
  margin: 0;
  background-color: #FF6B6B;
  color: #ffffff;
}

.send-btn-disabled {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  flex-shrink: 0;
  padding: 0;
  margin: 0;
  background-color: #cccccc;
  color: #ffffff;
}
