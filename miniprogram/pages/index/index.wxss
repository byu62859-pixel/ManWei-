.index-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--mw-cream);
}

/* ========== 搜索区 ========== */
.search-area {
  background: var(--mw-surface);
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 53, 97, 0.05);
  flex-shrink: 0;
}

.search-box {
  display: flex;
  align-items: center;
  background: var(--mw-cream);
  border-radius: 40rpx;
  padding: 0 28rpx;
  height: 80rpx;
  border: 2rpx solid transparent;
  transition: all var(--mw-dur-fast) var(--mw-ease);
}

.search-box:focus-within {
  border-color: var(--mw-coral);
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 107, 0.10);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--mw-text);
  height: 100%;
}

.search-input::placeholder {
  color: var(--mw-text-muted);
}

.search-btn {
  font-size: 28rpx;
  color: var(--mw-coral);
  font-weight: 700;
  padding-left: 16rpx;
  letter-spacing: 0.05em;
}

/* ========== 类型 Tab ========== */
.type-tabs {
  position: relative;
  z-index: 200;
  white-space: nowrap;
  background: var(--mw-surface);
  padding: 16rpx 24rpx;
  gap: 12rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  flex-shrink: 0;
}

::-webkit-scrollbar {
  display: none;
}

.type-tab {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 28rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--mw-text-soft);
  background: var(--mw-cream);
  border-radius: 32rpx;
  flex-shrink: 0;
  border: 2rpx solid transparent;
  transition: all var(--mw-dur-fast) var(--mw-ease);
}

.type-tab:active {
  opacity: 0.75;
}

.type-tab.active {
  background: linear-gradient(135deg, var(--mw-coral) 0%, var(--mw-peach) 100%);
  color: #fff;
  font-weight: 600;
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.28);
}

/* ========== 动漫列表 ========== */
.anime-list {
  flex: 1;
}

.anime-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  width: 100%;
}

.anime-card {
  background: var(--mw-surface);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(45, 53, 97, 0.07);
  box-sizing: border-box;
  transition: transform var(--mw-dur-normal) var(--mw-ease-spring),
              box-shadow var(--mw-dur-normal) var(--mw-ease) !important;
  animation: mw-fadeSlideUp var(--mw-dur-slow) var(--mw-ease-out) forwards;
  opacity: 1;
}

.anime-card:active {
  transform: scale(0.97) !important;
  box-shadow: 0 1rpx 8rpx rgba(45, 53, 97, 0.04) !important;
}

.card-cover {
  width: 100%;
  aspect-ratio: 3 / 4;
  height: auto;
  background: var(--mw-cream-deep);
  position: relative;
  overflow: hidden;
}

.card-cover::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 48rpx;
  background: linear-gradient(to top, rgba(45, 53, 97, 0.12), transparent);
}

.cover-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: var(--mw-cream-deep);
}

.cover-placeholder-icon {
  font-size: 48rpx;
  opacity: 0.3;
}

.cover-placeholder-text {
  font-size: 22rpx;
  color: var(--mw-text-muted);
}

.card-info {
  padding: 16rpx 14rpx;
}

.card-name {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--mw-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
  line-height: 1.3;
}

.card-meta {
  display: flex;
  align-items: center;
}

.card-type {
  display: inline-flex;
  align-items: center;
  font-size: 18rpx;
  color: var(--mw-coral);
  background: var(--mw-coral-soft);
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  color: var(--mw-text-muted);
  font-size: 28rpx;
  animation: mw-scaleIn var(--mw-dur-slow) var(--mw-ease-spring) forwards;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.3;
  margin-bottom: 16rpx;
}

/* ========== 加载更多 ========== */
.load-more {
  text-align: center;
  padding: 28rpx;
  color: var(--mw-text-muted);
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.load-more::before,
.load-more::after {
  content: '';
  width: 40rpx;
  height: 2rpx;
  background: var(--mw-border);
}

/* ========== 加载遮罩 ========== */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(251, 249, 247, 0.85);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  animation: mw-fadeSlideUp var(--mw-dur-normal) var(--mw-ease-out) forwards;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--mw-coral-soft);
  border-top-color: var(--mw-coral);
  border-radius: 50%;
  animation: mw-spin 0.8s linear infinite;
}

@keyframes mw-spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--mw-coral);
  font-weight: 500;
}